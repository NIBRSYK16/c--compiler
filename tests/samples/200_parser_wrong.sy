int add(int x, int y) {
    return x + y;
}

void doNothing() {
    return;
}

void printSum(int a, int b) {
    int sum;
    sum = a + b;
    return;
}

float multiply(float x, float y) {
    return x * y;
}

int factorial(int n) {
    if (n <= 1) {
        return 1;
    } else {
        return n * factorial(n - 1);
    }
}

int max(int x, int y) {
    if (x > y) {
        return x;
    } else {
        return y;
    }
}

float divide(float x, float y) {
    if (y != 0.0) {
        return x / y;
    } else {
        return 0.0;
    }
}

